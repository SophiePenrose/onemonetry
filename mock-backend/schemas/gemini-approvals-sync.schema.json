{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gemini-approvals-sync.schema.json",
  "title": "Gemini Approval Sync Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "request_id", "approvals"],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "gemini-handoff-v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 3
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence_id", "step_number", "approval_status"],
        "properties": {
          "sequence_id": { "type": "string", "minLength": 1 },
          "step_number": { "type": "integer", "minimum": 1 },
          "approval_status": {
            "type": "string",
            "enum": ["pending", "approved", "rejected", "sent", "paused"]
          },
          "approved_by": { "type": "string" },
          "approved_at": { "type": "string", "format": "date-time" },
          "review_notes": { "type": "string" }
        }
      }
    }
  }
}
