{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gemini-handoff-response.schema.json",
  "title": "Gemini Handoff Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "request_id",
    "response_id",
    "completed_at",
    "status",
    "sheet_write",
    "sequence_outputs",
    "errors"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "gemini-handoff-v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 3
    },
    "response_id": {
      "type": "string",
      "minLength": 3
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "error"]
    },
    "sheet_write": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sheet_id", "sheet_tab", "rows_written", "range"],
      "properties": {
        "sheet_id": { "type": "string", "minLength": 1 },
        "sheet_tab": { "type": "string", "minLength": 1 },
        "rows_written": { "type": "integer", "minimum": 0 },
        "range": { "type": "string", "minLength": 1 }
      }
    },
    "sequence_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["company_number", "person_id", "sequence_id", "qc", "steps", "yamm_rows"],
        "properties": {
          "company_number": { "type": "string", "minLength": 1 },
          "person_id": { "type": "string", "minLength": 1 },
          "sequence_id": { "type": "string", "minLength": 1 },
          "qc": {
            "type": "object",
            "additionalProperties": false,
            "required": ["passed", "score", "notes"],
            "properties": {
              "passed": { "type": "boolean" },
              "score": { "type": "number" },
              "notes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["step_number", "step_type", "day_offset", "subject", "body"],
              "properties": {
                "step_number": { "type": "integer", "minimum": 1 },
                "step_type": { "type": "string", "minLength": 1 },
                "day_offset": { "type": "integer", "minimum": 0 },
                "subject": { "type": "string", "minLength": 1 },
                "body": { "type": "string", "minLength": 1 },
                "citations": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "yamm_rows": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["Subject", "Body", "Company", "CompanyNumber", "PriorityRank", "SequenceId", "StepNumber", "ApprovalStatus"],
              "properties": {
                "To": { "type": "string" },
                "Subject": { "type": "string", "minLength": 1 },
                "Body": { "type": "string", "minLength": 1 },
                "Company": { "type": "string", "minLength": 1 },
                "CompanyNumber": { "type": "string", "minLength": 1 },
                "PriorityRank": { "type": "integer", "minimum": 1 },
                "SequenceId": { "type": "string", "minLength": 1 },
                "StepNumber": { "type": "integer", "minimum": 1 },
                "ApprovalStatus": {
                  "type": "string",
                  "enum": ["pending", "approved", "rejected", "sent", "paused"]
                }
              }
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "retryable": { "type": "boolean" },
          "scope": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
