{
  "name": "onemonetry",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "bash ./start.sh",
    "start:dev": "LIGHTWEIGHT_RUNTIME=true IGNORE_RUNTIME_SIGTERM=true FRONTEND_HOST=0.0.0.0 FRONTEND_PORT=5174 bash ./start.sh",
    "start:backend": "npm --prefix ./mock-backend start",
    "start:backend:light": "LIGHTWEIGHT_RUNTIME=true npm --prefix ./mock-backend start",
    "start:frontend": "npm --prefix ./frontend run dev",
    "smoke:api": "bash ./scripts/smoke-api.sh",
    "smoke:e2e:quick": "bash ./scripts/smoke-e2e-quick.sh",
    "benchmark:scoring": "node ./scripts/scoring-calibration-benchmark.mjs",
    "benchmark:delta": "node ./scripts/scoring-calibration-benchmark-delta.mjs",
    "benchmark:apply-review": "node ./scripts/scoring-calibration-apply-review.mjs",
    "import:monitor-list": "node ./scripts/import-monitor-list-bulk.mjs",
    "import:monitor-seed-list": "node ./scripts/import-monitor-seed-list.mjs",
    "import:endole-live": "node ./scripts/import-endole-live.mjs",
    "gemini:weekly:bundle": "node ./scripts/gemini-weekly-export-bundle.mjs",
    "logs": "bash -lc 'echo Backend: && tail -n 120 /tmp/onemonetry-backend.log && echo && echo Frontend: && tail -n 120 /tmp/onemonetry-frontend.log'",
    "logs:backend": "tail -n 120 /tmp/onemonetry-backend.log",
    "logs:frontend": "tail -n 120 /tmp/onemonetry-frontend.log",
    "test:backend": "npm --prefix ./mock-backend test",
    "test:frontend": "npm --prefix ./frontend test"
  }
}
