# Copy this file to .env and fill in your keys.
# The server/startup scripts load .env automatically via dotenv/shell source.

# -----------------------------------------------------------------------------
# Required core integrations
# -----------------------------------------------------------------------------

# OpenAI API key (analysis + advanced email generation)
OPENAI_API_KEY=replace_with_openai_api_key

# Companies House API key (lookups + filing monitor + ownership refresh)
COMPANIES_HOUSE_API_KEY=replace_with_companies_house_api_key

# Optional alias accepted by backend code
# CH_API_KEY=replace_with_companies_house_api_key

# Optional model/base URL overrides
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional startup guard: fail startup when OPENAI_API_KEY is missing/placeholder
# REQUIRE_OPENAI=false

# -----------------------------------------------------------------------------
# Runtime profile and process controls
# -----------------------------------------------------------------------------

# Lightweight runtime defaults in start.sh are true for local stability.
# Set false to run full scheduler/worker profile.
# LIGHTWEIGHT_RUNTIME=true

# Ignore SIGTERM in local runtime (default true in start.sh)
# IGNORE_RUNTIME_SIGTERM=true

# Heap cap used by start.sh when launching backend
# NODE_MAX_OLD_SPACE_MB=1024

# -----------------------------------------------------------------------------
# Email generation controls
# -----------------------------------------------------------------------------

# Fail closed for live generation (strict) or return best draft with QC metadata (preview-friendly)
# EMAIL_LLM_FAIL_CLOSED=false

# Optional live generation tuning
# EMAIL_LLM_MAX_ATTEMPTS=2
# EMAIL_LLM_MAX_PROMPT_CHARS=10000
# EMAIL_LLM_MAX_TOKENS=700
# EMAIL_LLM_MIN_QC_SCORE=65

# -----------------------------------------------------------------------------
# Optional enrichment/data providers
# -----------------------------------------------------------------------------

# Optional supplementary lookup providers
# ENABLE_NEWS_LOOKUP=true
# NEWS_API_KEY=replace_with_news_api_key_optional
# LUSHA_API_KEY=replace_with_lusha_api_key_optional

# Optional external signal connectors (URL templates support placeholders:
# {company_number}, {company_name}, {company_name_encoded}, {company_domain}, {company_domain_encoded})
# ENDOLE_API_KEY=replace_with_endole_key
# ENDOLE_URL_TEMPLATE=https://example.com/endole?company={company_number}

# OPENCORPORATES_API_TOKEN=replace_with_opencorporates_token
# OPENCORPORATES_URL_TEMPLATE=https://example.com/opencorporates?company={company_number}

# SIMILARWEB_API_KEY=replace_with_similarweb_key
# SIMILARWEB_URL_TEMPLATE=https://example.com/similarweb?domain={company_domain}

# BUILTWITH_API_KEY=replace_with_builtwith_key
# BUILTWITH_URL_TEMPLATE=https://example.com/builtwith?domain={company_domain}

# ADZUNA_APP_ID=replace_with_adzuna_app_id
# ADZUNA_APP_KEY=replace_with_adzuna_app_key
# ADZUNA_URL_TEMPLATE=https://example.com/adzuna?company={company_name_encoded}

# CRUNCHBASE_API_KEY=replace_with_crunchbase_key
# CRUNCHBASE_URL_TEMPLATE=https://example.com/crunchbase?company={company_name_encoded}

# CLEARBIT_API_KEY=replace_with_clearbit_key
# CLEARBIT_URL_TEMPLATE=https://example.com/clearbit?domain={company_domain}

# Optional connector auth overrides (defaults: header=Authorization, scheme=Bearer)
# ENDOLE_AUTH_HEADER=Authorization
# ENDOLE_AUTH_SCHEME=Bearer
# OPENCORPORATES_AUTH_HEADER=Authorization
# OPENCORPORATES_AUTH_SCHEME=Bearer
# SIMILARWEB_AUTH_HEADER=Authorization
# SIMILARWEB_AUTH_SCHEME=Bearer
# BUILTWITH_AUTH_HEADER=Authorization
# BUILTWITH_AUTH_SCHEME=Bearer
# ADZUNA_AUTH_HEADER=Authorization
# ADZUNA_AUTH_SCHEME=Bearer
# CRUNCHBASE_AUTH_HEADER=Authorization
# CRUNCHBASE_AUTH_SCHEME=Bearer
# CLEARBIT_AUTH_HEADER=Authorization
# CLEARBIT_AUTH_SCHEME=Bearer

# Optional connector timeout
# EXTERNAL_SIGNAL_TIMEOUT_MS=7000

# Optional signal sync toggles
# DEFAULT_RUN_EXTERNAL_SIGNAL_SYNC=false
# ANALYSIS_QUEUE_EXTERNAL_SIGNAL_SYNC=false

# -----------------------------------------------------------------------------
# Tech enrichment + scheduler controls
# -----------------------------------------------------------------------------

# Tech enrichment runtime
# TECH_ENRICHMENT_TIMEOUT_MS=4500
# TECH_ENRICHMENT_MAX_PAGES=6
# TECH_ENRICHMENT_REFRESH_DAYS=21
# TECH_ENRICHMENT_DEEP_SCAN_MODE=auto
# TECH_ENRICHMENT_HIGH_VALUE_TURNOVER=25000000

# Background enrichment seeder
# TECH_ENRICHMENT_SEED_ENABLED=true
# TECH_ENRICHMENT_SEED_INTERVAL_MS=21600000
# TECH_ENRICHMENT_SEED_INITIAL_DELAY_MS=45000
# TECH_ENRICHMENT_SEED_LIMIT=1200
# TECH_ENRICHMENT_SEED_MAX_REFRESH=60
# TECH_ENRICHMENT_SEED_DEEP_SCAN_MODE=off

# Analysis queue + enrichment controls
# ANALYSIS_QUEUE_INTERVAL_MS=15000
# ANALYSIS_QUEUE_BATCH_SIZE=2
# ANALYSIS_QUEUE_ENRICHMENT_DEEP_SCAN_MODE=off
# ANALYSIS_QUEUE_ENRICHMENT_MAX_PAGES=6
# ANALYSIS_QUEUE_ENRICHMENT_REFRESH_DAYS=21
# ANALYSIS_QUEUE_ENRICHMENT_TIMEOUT_MS=4500

# -----------------------------------------------------------------------------
# Import/monitor storage controls
# -----------------------------------------------------------------------------

# Companies House monitor batch size
# CH_MONITOR_BATCH_SIZE=50

# Override processed zips directory
# PROCESSED_ZIPS_DATA_DIR=mock-backend/data
