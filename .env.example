# Copy this file to .env and fill in your keys
# The server loads these automatically on startup via dotenv

# OpenAI API key — enables deep LLM analysis of company filings
# Get one from: https://platform.openai.com/api-keys
OPENAI_API_KEY=replace_with_openai_api_key

# Optional: change the model (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Companies House API key — enables live company lookups
# Get one free from: https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=replace_with_companies_house_api_key

# Optional: rate limit delay for CH API calls (milliseconds, default: 600)
# CH_API_DELAY_MS=600

# Optional: override OpenAI API base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: runtime profile for local dev stability (default in start.sh: true)
# When true, background schedulers/workers are disabled to reduce memory pressure.
# LIGHTWEIGHT_RUNTIME=true

# Optional: backend heap cap used by start.sh (default: 1024)
# NODE_MAX_OLD_SPACE_MB=1024

# Optional: live email generation memory/quality tuning
# EMAIL_LLM_MAX_ATTEMPTS=2
# EMAIL_LLM_MAX_PROMPT_CHARS=10000
# EMAIL_LLM_MAX_TOKENS=700
# EMAIL_LLM_MIN_QC_SCORE=65

# Optional: strict fail-closed behavior for live generation (default in start.sh: false for local preview)
# true  => return 503 when quality floor/gates are not met
# false => return best live draft with QC metadata for manual review
# EMAIL_LLM_FAIL_CLOSED=false

# Optional: batch size for Companies House monitor (default: 50)
# CH_MONITOR_BATCH_SIZE=50

# Optional: override processed zips data directory (default: mock-backend/data)
# PROCESSED_ZIPS_DATA_DIR=mock-backend/data
